{
  "name": "llm-weather",
  "version": "0.1.0-alpha.11",
  "start": "llmweather",
  "description": "How hot is it markdown?",
  "params": {
    "location": {
      "type": "text/markdown"
    },
    "systemParser": {
      "type": "text/markdown"
    },
    "userParser": {
      "type": "text/markdown"
    },
    "systemReport": {
      "type": "text/markdown"
    }
  },
  "steps": {
    "llmweather": {
      "type": "httpjson",
      "url": "http://192.168.1.75:8000/v1/chat/completions",
      "method": "POST",
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer local-key"
      },
      "body": {
        "model": "local-mistral",
        "messages": [
          {
            "role": "system",
            "content": "{{params.systemParser}}"
          },
          {
            "role": "user",
            "content": "{{params.userParser}} \"How hot is it in {{params.location}}?\"\n}"
          }
        ],
        "temperature": 0,
        "max_tokens": 500,
        "response_format": { "type": "json_object" }
      },
      "exports": {
        "data": {
          "ref": "{{output.body.choices[0].message.content}}",
          "type": "application/json",
          "schema": {
            "type": "object",
            "properties": {
              "location": { "type": "string" }
            },
            "required": ["location"]
          }
        },
        "data-markdown": {
          "ref": "{{output.body.choices[0].message.content}}",
          "type": "text/markdown"
        }
      },
      "on": {
        "success": "getlocation"
      }
    },
    "getlocation": {
      "type": "httpjson",
      "url": "https://geocoding-api.open-meteo.com/v1/search?name={{steps.llmweather.exports.data.location}}&count=1&language=en&format=json",
      "on": {
        "success": "getforecast"
      }
    },
    "getforecast": {
      "type": "httpjson",
      "url": "https://api.open-meteo.com/v1/forecast?latitude={{steps.getlocation.output.body.results[0].latitude}}&longitude={{steps.getlocation.output.body.results[0].longitude}}&current=temperature_2m&forecast_days=1",
      "on": {
        "success": "report"
      }
    },
    "report": {
      "type": "httpjson",
      "url": "http://192.168.1.75:8000/v1/chat/completions",
      "method": "POST",
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer local-key"
      },
      "body": {
        "model": "local-mistral",
        "messages": [
          {
            "role": "system",
            "content": "{{params.systemReport}}"
          },
          {
            "role": "user",
            "content": "{{steps.llmweather.exports.data.location}} latitude: {{steps.getlocation.output.body.results[0].latitude}}. \n{{steps.llmweather.exports.data.location}} longitude: {{steps.getlocation.output.body.results[0].longitude}}.  \n\n Current weather data for this location\n\n{{steps.getforecast.output.body}} \n\n Users Question: \"How hot is it in {{params.location}}?\"\n}"
          }
        ],
        "temperature": 0.7,
        "max_tokens": 500
      },
      "exports": {
        "llm-forecast": {
          "ref": "{{output.body.choices[0].message.content}}",
          "type": "text/markdown"
        }
      }
    }
  }
}
