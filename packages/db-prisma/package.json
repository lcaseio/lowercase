{
  "name": "@lcase/db-prisma",
  "version": "0.1.0-alpha.12",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "prisma generate",
    "build": "pnpm run generate && tsc --incremental false",
    "typecheck": "pnpm run generate && tsc --noEmit --incremental false",
    "migrate": "mkdir -p ../../lcase-db/sqlite && prisma migrate deploy",
    "test": "echo test",
    "lint": "echo lint"
  },
  "packageManager": "pnpm@10.17.1",
  "devDependencies": {
    "@lcase/ports": "workspace:*",
    "@lcase/types": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "prisma": "^7.8.0"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2"
  }
}
