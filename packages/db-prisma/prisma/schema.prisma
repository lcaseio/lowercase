// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "sqlite"
}

enum ArtifactFormat {
  json
  text
  markdown
  bytes
}

enum RunStatus {
  requested
  started
  completed
  failed
}

model Flow {
  id          String        @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  versions    FlowVersion[]
  sims        Sim[]
  runs        Run[]
}

model FlowVersion {
  id             String   @id @default(cuid())
  flowId         String
  sequence       Int
  definitionHash String
  versionLabel   String?
  description    String?
  createdAt      DateTime @default(now())

  flow Flow @relation(fields: [flowId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sims Sim[]
  runs Run[]

  @@unique([flowId, sequence])
  @@index([flowId])
}

model Artifact {
  hash        String         @id
  time        DateTime       @default(now())
  label       String?
  filename    String?
  contentType String?
  size        Int?
  format      ArtifactFormat?

  @@index([time])
}

model Sim {
  id            String      @id @default(cuid())
  name          String
  description   String?
  flowId        String
  flowVersionId String
  forkSpecHash  String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  flow        Flow        @relation(fields: [flowId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  flowVersion FlowVersion @relation(fields: [flowVersionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([createdAt])
  @@index([flowId])
  @@index([flowVersionId])
}

model Run {
  id            String      @id
  traceId       String
  status        RunStatus
  source        String
  flowId        String?
  flowVersionId String?
  flowDefHash   String
  parentRunId   String?
  forkSpecHash  String?
  runParamsHash String?
  startTime     DateTime?
  endTime       DateTime?
  duration      Float?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  flow            Flow?                @relation(fields: [flowId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  flowVersion     FlowVersion?         @relation(fields: [flowVersionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stepProjections RunStepProjection[]

  @@index([createdAt])
  @@index([flowId])
  @@index([flowVersionId])
  @@index([parentRunId])
}

model RunStepProjection {
  runId        String
  stepId       String
  status       String?
  startTime    DateTime?
  endTime      DateTime?
  duration     Float?
  reusedTime   DateTime?
  wasReused    Boolean?
  outputHash   String?
  argsHash     String?
  exportHashes String?

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([runId, stepId])
  @@index([runId])
  @@index([status])
}
